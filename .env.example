# Application
APP_NAME=Naive Bayes Classifier API
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=naive_bayes

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# File Storage
DATA_DIR=data
UPLOAD_DIR=uploads
ALLOWED_EXTENSIONS=.xlsx,.xls

# Model
MODEL_CACHE_TTL=3600
TARGET_COLUMN=Durasi Mendapat Kerja
